{
  "name": "wingman",
  "version": "1.2.1",
  "description": "Personal automation system: email, news, and Slack notifications",
  "type": "module",
  "bin": {
    "wingman": "./cli.js"
  },
  "scripts": {
    "start": "pm2 start ecosystem.config.cjs",
    "stop": "pm2 delete wingman",
    "restart": "npm run stop && npm start",
    "status": "pm2 list",
    "dev": "tsx scripts/dev.js",
    "log": "tsx scripts/log.js",
    "setup": "tsx scripts/setup.js",
    "test": "vitest run"
  },
  "dependencies": {
    "@notionhq/client": "^2.2.0",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "dotenv": "^16.4.5",
    "node-fetch": "^3.3.2",
    "rss-parser": "^3.13.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "pm2": "^6.0.14",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
