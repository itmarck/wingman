# ─── MICROSOFT GRAPH (Outlook / Hotmail) ──────────────────────
# Get these at: https://portal.azure.com → App registrations
MS_CLIENT_ID=
MS_CLIENT_SECRET=
# Use "consumers" for personal accounts (Outlook/Hotmail), "common" for work+personal, or your org's tenant ID
MS_TENANT_ID=consumers
# Generated via: node agents/email/auth.js
# Scope: Mail.ReadWrite (read, mark as read, archive, trash). Re-run auth.js if upgrading from Mail.Read.
MS_REFRESH_TOKEN=

# ─── SLACK WEBHOOKS ───────────────────────────────────────────
# Create at: https://api.slack.com/apps → your app → Incoming Webhooks
SLACK_WEBHOOK_EMAIL_IMPORTANT=https://hooks.slack.com/services/...
SLACK_WEBHOOK_EMAIL_DIGEST=https://hooks.slack.com/services/...
SLACK_WEBHOOK_NEWS=https://hooks.slack.com/services/...
SLACK_WEBHOOK_ALERTS=https://hooks.slack.com/services/...
SLACK_WEBHOOK_LOGS=https://hooks.slack.com/services/...

# ─── GENERAL ──────────────────────────────────────────────────
# How many hours back to look for emails on each cycle
EMAIL_LOOKBACK_HOURS=1

# Reddit trending detection — two-tier system
# Formula: (score × comments) / post_age_hours
# Posts between THRESHOLD and VIRAL are filtered by interest_categories (Claude decides relevance)
# Posts above VIRAL are always notified (massive events, no interest filter)
REDDIT_TRENDING_THRESHOLD=500
REDDIT_TRENDING_VIRAL=5000

# Note: No ANTHROPIC_API_KEY needed.
# Classification uses Claude Code CLI (claude -p "...") with your Pro/Max session.
# Make sure Claude Code is installed and authenticated: claude --version
